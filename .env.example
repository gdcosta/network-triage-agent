# Anthropic API key. The LLM is the brain of this agent — SOUL.md is its
# system prompt, and it produces every detection / triage / dedup decision.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
SOUL_PATH=SOUL.md

# --- LLM provider (#36 / #73 cost+quality A/B) ----------------------------
# "anthropic" (default): Anthropic SDK. In k8s this still flows through the
#   DefenseClaw guardrail proxy via ANTHROPIC_BASE_URL — unchanged.
# "openai": talk to any OpenAI-compatible /v1 endpoint (e.g. the self-hosted
#   vLLM box). Set LLM_BASE_URL and point LLM_MODEL at the served model id.
#   Structured output uses response_format=json_schema (guided decoding).
LLM_PROVIDER=anthropic
# Required when LLM_PROVIDER=openai. Include the /v1 suffix, e.g.
#   LLM_BASE_URL=http://172.31.5.203:8000/v1
# and set LLM_MODEL=stelterlab/Qwen3-30B-A3B-Instruct-2507-AWQ
LLM_BASE_URL=
# vLLM api key. "EMPTY" works when vLLM was started without --api-key (the box
# is network-isolated). Sent as Authorization: Bearer on every call.
LLM_API_KEY=EMPTY

# Microsoft Teams Workflows webhook URL — receives raw AdaptiveCard JSON.
TEAMS_WEBHOOK_URL=

# How to launch the Splunk MCP server (stdio transport).
# Examples:
#   SPLUNK_MCP_COMMAND=uvx
#   SPLUNK_MCP_ARGS=splunk-mcp-server
# Or:
#   SPLUNK_MCP_COMMAND=docker
#   SPLUNK_MCP_ARGS=run --rm -i splunk-cisco-dc-erp-analysis-bob
SPLUNK_MCP_COMMAND=
SPLUNK_MCP_ARGS=

# Extra env vars passed to the Splunk MCP launch subprocess. Format:
# comma-separated KEY=VALUE pairs (no quotes). If your Splunk uses a
# self-signed cert, the Node `mcp-remote` bridge needs
# NODE_TLS_REJECT_UNAUTHORIZED=0 to skip cert verification.
SPLUNK_MCP_ENV=NODE_TLS_REJECT_UNAUTHORIZED=0

# Name of the MCP tool that runs an SPL search and returns rows.
# Common names: splunk_run_query, splunk_search, run_search. Adapt to
# whatever your Splunk MCP server exposes.
SPLUNK_TOOL_NAME=splunk_run_query

# Max rows the tool returns per call. The MCP server caps at 1000.
# Meraki scans group by (networkId, sourcetype, type) — for large fleets
# this can fan out, so default to the cap and watch for splunk.truncated
# events in stdout.
SPLUNK_ROW_LIMIT=1000

# Polling configuration.
POLL_INTERVAL_SECONDS=30
EARLIEST_TIME=-5m
LATEST_TIME=now

# Deep-link bases for Adaptive Card actions.
SPLUNK_BASE_URL=https://splunk.example.com
MERAKI_BASE_URL=https://dashboard.meraki.com

# Fleet roster JSON. Maps 3-digit store IDs to display names used in the
# card's top-level `store_name` field. Defaults to ./store_registry.json.
# If missing, cards fall back to "Store {id} - {site}" using the LLM's
# `site` value. Copy store_registry.example.json -> store_registry.json
# and edit for your fleet.
STORE_REGISTRY_PATH=store_registry.json

# -------------------------------------------------------------------------
# triage_mcp.py — the companion MCP server consumed by the chat bot.
#
# triage_mcp queries a DIFFERENT Splunk than the agent. The agent queries
# the production telemetry Splunk (above: SPLUNK_MCP_COMMAND etc → bob)
# for retail-store network data. triage_mcp queries the cluster's
# observability Splunk (linda) for the agent's own JSONL events — the
# triage.report events that record what was alerted, dedup'd, recovered.
#
# In k8s these are separate Secrets (kl-triage-secrets vs kl-triage-mcp-secrets).
# For local dev, set these EXPLICITLY so the two processes don't fight over
# the same SPLUNK_MCP_* vars. If TRIAGE_MCP_SPLUNK_* are unset, triage_mcp
# falls back to SPLUNK_MCP_* — handy when you only have one Splunk locally.
# -------------------------------------------------------------------------

# Example for linda (cluster observability Splunk):
#   TRIAGE_MCP_SPLUNK_COMMAND=npx
#   TRIAGE_MCP_SPLUNK_ARGS=-y mcp-remote https://172.31.1.82:8089/services/mcp --header "Authorization: Bearer <TOKEN>"
TRIAGE_MCP_SPLUNK_COMMAND=
TRIAGE_MCP_SPLUNK_ARGS=
TRIAGE_MCP_SPLUNK_TOOL_NAME=splunk_run_query
TRIAGE_MCP_SPLUNK_ROW_LIMIT=1000

# Extra env vars forwarded to the Splunk MCP subprocess (mcp-remote / npx).
# Same comma-separated KEY=VALUE format as SPLUNK_MCP_ENV. Required when
# linda's Splunk uses a self-signed cert — without this the Node bridge
# rejects the TLS handshake. Falls back to SPLUNK_MCP_ENV if unset.
TRIAGE_MCP_ENV=NODE_TLS_REJECT_UNAUTHORIZED=0

# Splunk index where the agent's JSONL events are stored by the OTel collector.
# Default matches the workshop cluster setup.
TRIAGE_EVENT_INDEX=k8s_ws_logs

# How triage_mcp reaches the agent's live /state HTTP endpoint. In k8s the
# Service DNS handles this; locally point at wherever your agent is running
# with AGENT_STATE_PORT set.
TRIAGE_AGENT_STATE_URL=http://triage-agent-state.net-triage-agent.svc.cluster.local:8080/state
TRIAGE_AGENT_HTTP_TIMEOUT=3.0

# Performance knobs (defaults are usually fine):
#   - SPLUNK_TIMEOUT: hard per-query timeout (seconds)
#   - SPLUNK_CACHE_TTL: in-process cache for history-shaped queries (seconds);
#     live tools are NEVER cached. Set 0 to disable caching for testing.
TRIAGE_SPLUNK_TIMEOUT=10
TRIAGE_SPLUNK_CACHE_TTL=30

# Where triage_mcp listens for the bot to connect (FastMCP SSE transport).
TRIAGE_MCP_HOST=0.0.0.0
TRIAGE_MCP_PORT=8081

# -------------------------------------------------------------------------
# main.py — opt-in HTTP /state endpoint for triage_mcp to query.
# Default 0 (disabled). Set to a port (typically 8080) to enable.
# -------------------------------------------------------------------------
AGENT_STATE_PORT=0
